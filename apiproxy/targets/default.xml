<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<TargetEndpoint name="default">
  <Description/>
  <FaultRules/>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>AM-ConfigureGoogleMapApiKey</Name>
      </Step>
      <Step>
        <Name>AM-DisableTargetSuffix</Name>
      </Step>
    </Request>
    <Response/>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <Flows/>
  <HTTPTargetConnection>
    <Properties/>
    <!--<URL>https://maps.googleapis.com</URL>-->
    <LoadBalancer>
      <Server name="google-map-api"/>
    </LoadBalancer>
    <Path>{targetpath}</Path>
  </HTTPTargetConnection>
</TargetEndpoint>
