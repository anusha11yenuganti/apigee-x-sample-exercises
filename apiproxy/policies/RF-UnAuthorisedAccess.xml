<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<RaiseFault continueOnError="false" enabled="true" name="RF-UnAuthorisedAccess">
  <DisplayName>RF-UnAuthorisedAccess</DisplayName>
  <FaultResponse>
    <Set>
      <Payload contentType="application/json">{"code":401, "message":"Invalid API Key"}</Payload>
      <StatusCode>401</StatusCode>
      <ReasonPhrase>Unauthorised</ReasonPhrase>
    </Set>
  </FaultResponse>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
</RaiseFault>
