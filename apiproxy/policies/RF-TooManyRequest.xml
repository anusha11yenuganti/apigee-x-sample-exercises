<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<RaiseFault continueOnError="false" enabled="true" name="RF-TooManyRequest">
  <DisplayName>RF-TooManyRequest</DisplayName>
  <FaultResponse>
    <Set>
      <Payload contentType="application/json">{"code":429, "message":"TooManyRequest"}</Payload>
      <StatusCode>429</StatusCode>
      <ReasonPhrase>Too Many Request</ReasonPhrase>
    </Set>
  </FaultResponse>
  <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
</RaiseFault>
